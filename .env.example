VITE_API_BASE=http://localhost:8787
VITE_LIVEKIT_ROOM=jarvis-room
VITE_VOICE_LABEL=FREE CUSTOM VOICE ?

PORT=8787
LIVEKIT_URL=wss://YOUR_LIVEKIT_URL
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/livekit-agent
N8N_RESPONSE_FIELD=output
VOICE_SERVICE_URL=http://localhost:8000

AGENT_ROOM=jarvis-room
AGENT_NAME=jarvis-agent

# voice mode: free | minimax
VOICE_MODE=free

# Free mode models (self-hosted/open-source via your inference stack)
FREE_STT_MODEL=local/whisper
FREE_LLM_MODEL=openai/gpt-4.1-mini
FREE_TTS_MODEL=local/xtts

# Optional MiniMax mode
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_VOICE_ID=
MINIMAX_MODEL=speech-2.8-hd
MINIMAX_STT_MODEL=deepgram/nova-3:en
MINIMAX_LLM_MODEL=openai/gpt-4.1-mini
MINIMAX_TTS_MODEL=speech-2.8-hd

# Custom voice cloning (free path)
CUSTOM_VOICE_LANG=es
CUSTOM_VOICE_WAV_URL=
CUSTOM_VOICE_WAV_PATH=/tmp/custom_voice.wav
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
AGENT_SYSTEM_PROMPT_FILE=agent/system_prompt_es.md
